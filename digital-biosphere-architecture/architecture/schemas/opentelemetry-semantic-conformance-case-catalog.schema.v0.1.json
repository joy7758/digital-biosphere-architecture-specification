{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tmai:schema:opentelemetry-semantic-conformance-case-catalog:0.1",
  "title": "TMAI OpenTelemetry Semantic Conformance Case Catalog v0.1",
  "description": "Machine-readable preregistration for OpenTelemetry semantic mapping, authority, privacy, cardinality, drift, and result-boundary conformance. Schema validity does not adopt a reference, execute tests, change child repositories, or prove production readiness.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_schema_version",
    "catalog_id",
    "status",
    "primary_repository",
    "decision_reference",
    "contract_binding",
    "case_groups",
    "cases",
    "semantic_rules",
    "effects"
  ],
  "properties": {
    "catalog_schema_version": {"const": "0.1"},
    "catalog_id": {"const": "TMAI-OTEL-SEMANTIC-CONFORMANCE-0.1"},
    "status": {"const": "ADOPTED_CONTRACT_NOT_EXECUTED"},
    "primary_repository": {"const": "digital-biosphere-architecture"},
    "decision_reference": {"const": "DQ-023"},
    "contract_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "otel_specification",
        "core_semconv",
        "genai_semconv_commit",
        "genai_schema_url",
        "otlp",
        "semantic_profile_id",
        "mapping_catalog_id",
        "mapping_catalog_path",
        "mapping_catalog_digest",
        "mapping_catalog_status"
      ],
      "properties": {
        "otel_specification": {"const": "v1.59.0@a824fb4eba795c5c65dd397b3d22e7c28e934de3"},
        "core_semconv": {"const": "v1.43.0@89aae438b3b3b0a8dd33003c9d70592baf7dbd0d"},
        "genai_semconv_commit": {"const": "2e994c6d59a93bb4fc1752c5378eedb9b8e14d6b"},
        "genai_schema_url": {"type": "null"},
        "otlp": {"const": "v1.11.0@790608c4d51e6ffc12210b541e8514cbed9e91a4"},
        "semantic_profile_id": {"const": "TMAI-OTEL-SEMANTIC-CONVENTIONS-PROFILE-0.1"},
        "mapping_catalog_id": {"const": "TMAI-OTEL-SEMANTIC-MAPPING-0.1"},
        "mapping_catalog_path": {"const": "architecture/opentelemetry-semantic-mapping.v0.1.json"},
        "mapping_catalog_digest": {"type": "null"},
        "mapping_catalog_status": {"const": "ADOPTED_CONTRACT_NOT_IMPLEMENTED"}
      }
    },
    "case_groups": {
      "type": "array",
      "minItems": 8,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/caseGroup"}
    },
    "cases": {
      "type": "array",
      "minItems": 46,
      "maxItems": 46,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/conformanceCase"}
    },
    "semantic_rules": {
      "const": [
        "ALL_47_MAPPING_IDS_MUST_BE_COVERED",
        "ALL_46_CASE_IDS_MUST_BE_UNIQUE_AND_GROUPED_EXACTLY_ONCE",
        "UNKNOWN_MAPPING_IDS_ARE_REJECTED",
        "SOURCE_STABILITY_AND_MAPPING_CATALOG_MUST_MATCH",
        "SENSITIVE_CONTENT_DEFAULT_DISABLED",
        "AUTHORITY_FIELDS_AND_NAMESPACES_ARE_REJECTED",
        "METRIC_HIGH_CARDINALITY_IDENTIFIERS_ARE_REJECTED",
        "FAILURE_PARTIAL_UNKNOWN_AND_LIMITATIONS_ARE_RETAINED",
        "ALL_EFFECTS_REMAIN_FALSE",
        "RESULT_SET_CANNOT_CLOSE_A_GATE"
      ]
    },
    "effects": {"$ref": "#/$defs/noEffects"}
  },
  "$defs": {
    "caseId": {"type": "string", "pattern": "^SEM-CF-[A-Z]{3,6}-[0-9]{3}$"},
    "mappingId": {"type": "string", "pattern": "^OTEL-SM-[0-9]{3}$"},
    "groupId": {
      "enum": [
        "SEM-CG-VERSION_SOURCE",
        "SEM-CG-CORE_STABLE",
        "SEM-CG-GENAI_METADATA",
        "SEM-CG-SENSITIVE_CONTENT",
        "SEM-CG-DEPRECATED_DRIFT",
        "SEM-CG-AUTHORITY_BOUNDARY",
        "SEM-CG-CARDINALITY",
        "SEM-CG-RESULT_BOUNDARY"
      ]
    },
    "gateRef": {
      "enum": ["DQ-018", "DQ-020", "DQ-022", "DQ-023", "PR-G2", "PR-G3", "PR-G5", "PR-G6"]
    },
    "caseGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_id", "title", "purpose", "required_for_gates", "required_case_ids"],
      "properties": {
        "group_id": {"$ref": "#/$defs/groupId"},
        "title": {"type": "string", "minLength": 1, "maxLength": 256},
        "purpose": {"type": "string", "minLength": 1, "maxLength": 1024},
        "required_for_gates": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/gateRef"}
        },
        "required_case_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/caseId"}
        }
      }
    },
    "conformanceCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "group_id",
        "title",
        "case_class",
        "mapping_ids",
        "signal_surfaces",
        "fixture_class",
        "stimulus",
        "expected_outcome",
        "required_assertions",
        "required_evidence",
        "forbidden_effects",
        "gate_refs",
        "authorization_prerequisites",
        "implementation_required",
        "current_execution_status"
      ],
      "properties": {
        "case_id": {"$ref": "#/$defs/caseId"},
        "group_id": {"$ref": "#/$defs/groupId"},
        "title": {"type": "string", "minLength": 1, "maxLength": 256},
        "case_class": {
          "enum": [
            "POSITIVE_MAPPING",
            "NEGATIVE_MAPPING",
            "VERSION_SOURCE",
            "DATA_GOVERNANCE",
            "DEPRECATED_DRIFT",
            "AUTHORITY_BOUNDARY",
            "CARDINALITY",
            "RESULT_BOUNDARY"
          ]
        },
        "mapping_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/mappingId"}
        },
        "signal_surfaces": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"enum": ["RESOURCE", "TRACE", "METRIC", "LOG", "EVENT", "ANY"]}
        },
        "fixture_class": {
          "enum": [
            "VALID_METADATA",
            "INVALID_VERSION",
            "MISSING_BINDING",
            "FORGED_AUTHORITY",
            "SYNTHETIC_SENSITIVE_CANARY",
            "DEPRECATED_FIELD",
            "UNKNOWN_FIELD",
            "CARDINALITY_OVERFLOW",
            "RESULT_DOCUMENT"
          ]
        },
        "stimulus": {"type": "string", "minLength": 1, "maxLength": 2048},
        "expected_outcome": {
          "enum": [
            "MAPPED_METADATA_ONLY",
            "REJECTED_WITH_DIAGNOSTIC",
            "RETAINED_LIMITATION",
            "FAIL_CLOSED_NO_EFFECT",
            "OPT_IN_REDACTED_METADATA_ONLY",
            "RESULT_NOT_ASSESSED"
          ]
        },
        "required_assertions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "required_evidence": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "forbidden_effects": {"const": "ALL_CANONICAL_AND_AUTHORITY_EFFECTS"},
        "gate_refs": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"$ref": "#/$defs/gateRef"}
        },
        "authorization_prerequisites": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {"type": "string", "minLength": 1, "maxLength": 512}
        },
        "implementation_required": {"const": true},
        "current_execution_status": {"const": "NOT_EXECUTED"}
      }
    },
    "noEffects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adopts_reference",
        "implements_validator",
        "executes_tests",
        "changes_child_repositories",
        "creates_telemetry",
        "creates_entity",
        "creates_identity",
        "creates_capability",
        "grants_permission",
        "creates_execution",
        "creates_evidence",
        "creates_verification",
        "creates_saee_evaluation",
        "authorizes_implementation",
        "authorizes_deployment",
        "closes_gate",
        "declares_production_ready"
      ],
      "properties": {
        "adopts_reference": {"const": false},
        "implements_validator": {"const": false},
        "executes_tests": {"const": false},
        "changes_child_repositories": {"const": false},
        "creates_telemetry": {"const": false},
        "creates_entity": {"const": false},
        "creates_identity": {"const": false},
        "creates_capability": {"const": false},
        "grants_permission": {"const": false},
        "creates_execution": {"const": false},
        "creates_evidence": {"const": false},
        "creates_verification": {"const": false},
        "creates_saee_evaluation": {"const": false},
        "authorizes_implementation": {"const": false},
        "authorizes_deployment": {"const": false},
        "closes_gate": {"const": false},
        "declares_production_ready": {"const": false}
      }
    }
  }
}
