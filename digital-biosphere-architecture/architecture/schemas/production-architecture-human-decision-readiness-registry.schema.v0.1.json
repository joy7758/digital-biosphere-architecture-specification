        "architecture_frozen": {"type": "boolean", "const": false},
        "implementation_authorized": {"type": "boolean", "const": false},
        "commit_authorized": {"type": "boolean", "const": false},
        "push_authorized": {"type": "boolean", "const": false},
        "collector_selected": {"type": "boolean", "const": false},
        "backend_selected": {"type": "boolean", "const": false},
        "configuration_created": {"type": "boolean", "const": false},
        "endpoint_created": {"type": "boolean", "const": false},
        "runtime_created": {"type": "boolean", "const": false},
