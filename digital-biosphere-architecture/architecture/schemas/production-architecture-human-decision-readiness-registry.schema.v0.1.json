    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reference_adopted",
        "architecture_frozen",
        "implementation_authorized",
        "commit_authorized",
        "push_authorized",
        "collector_selected",
        "backend_selected",
        "configuration_created",
        "endpoint_created",
        "runtime_created",
        "entity_created",
        "evidence_created",
        "permission_granted",
        "tests_executed",
        "deployment_authorized",
        "production_ready"
      ],
      "properties": {
        "reference_adopted": {"type": "boolean"},
        "architecture_frozen": {"type": "boolean"},
        "implementation_authorized": {"type": "boolean"},
        "commit_authorized": {"type": "boolean"},
        "push_authorized": {"type": "boolean"},
        "collector_selected": {"type": "boolean"},
