{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:tmai:schema:otlp-conformance-result-set:0.1",
  "title": "TMAI OTLP Conformance Result Set v0.1",
  "description": "Shape and fail-closed invariants for case-level OTLP conformance results. Schema validity does not mean a case or gate passed and does not authorize implementation, deployment, or production use.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "result_schema_version",
    "result_set_id",
    "status",
    "synthetic_example",
    "catalog_binding",
    "decision_bindings",
    "claim_scope",
    "implementation_binding",
    "validation_binding",
    "authority_boundary",
    "required_case_ids",
    "case_results",
    "summary",
    "reviews",
    "result",
    "result_reason",
    "frozen_at",
    "result_set_digest",
    "revocation",
    "effects"
  ],
  "properties": {
    "result_schema_version": {"const": "0.1"},
    "result_set_id": {"type": "string", "pattern": "^TMAI-OTLP-RESULT-[A-Z0-9._-]{6,96}$"},
    "status": {"enum": ["DRAFT", "FROZEN", "REVOKED", "ARCHIVED"]},
    "synthetic_example": {"type": "boolean"},
    "catalog_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog_id", "catalog_path", "catalog_digest", "catalog_status", "reference_tag", "reference_commit"],
      "properties": {
        "catalog_id": {"const": "TMAI-OTLP-CONFORMANCE-V1.11-0.1"},
        "catalog_path": {"const": "architecture/otlp-v1.11-conformance-cases.v0.1.json"},
        "catalog_digest": {"$ref": "#/$defs/nullableDigest"},
        "catalog_status": {"enum": ["PROPOSED_NOT_ADOPTED_NOT_EXECUTED", "ADOPTED_CONTRACT"]},
        "reference_tag": {"const": "v1.11.0"},
        "reference_commit": {"const": "790608c4d51e6ffc12210b541e8514cbed9e91a4"}
      }
    },
    "decision_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/decisionBinding"},
      "uniqueItems": true
    },
    "claim_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gate_id", "step_id", "environment_id", "environment_class", "topology_digest", "workload_ref", "window_started_at", "window_ended_at"],
      "properties": {
        "gate_id": {"enum": ["PR-G2", "PR-G3", "PR-G5", "PR-G6"]},
        "step_id": {"enum": ["S1", "S3A", "S3B", "S6", "S7"]},
        "environment_id": {"type": "string", "minLength": 1, "maxLength": 256},
        "environment_class": {"enum": ["SYNTHETIC_REFERENCE", "LOCAL_REFERENCE", "STAGING", "BOUNDED_PRODUCTION_PILOT"]},
        "topology_digest": {"$ref": "#/$defs/nullableDigest"},
        "workload_ref": {"$ref": "#/$defs/nullableString"},
        "window_started_at": {"$ref": "#/$defs/nullableDateTime"},
        "window_ended_at": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "implementation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "source_commit", "artifact_digest", "distribution_version", "component_manifest_digest", "configuration_digest", "runtime_environment_digest"],
      "properties": {
        "repository": {"$ref": "#/$defs/nullableUri"},
        "source_commit": {"$ref": "#/$defs/nullableCommit"},
        "artifact_digest": {"$ref": "#/$defs/nullableDigest"},
        "distribution_version": {"$ref": "#/$defs/nullableString"},
        "component_manifest_digest": {"$ref": "#/$defs/nullableDigest"},
        "configuration_digest": {"$ref": "#/$defs/nullableDigest"},
        "runtime_environment_digest": {"$ref": "#/$defs/nullableDigest"}
      }
    },
    "validation_binding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "validator_implementation_status",
        "validator_id",
        "validator_version",
        "validator_artifact_digest",
        "schema_validation",
        "semantic_validation",
        "case_set_reconciliation",
        "summary_reconciliation",
        "catalog_digest_verified",
        "decision_bindings_verified",
        "implementation_digests_verified",
        "environment_binding_verified",
        "validation_report_ref",
        "validation_completed_at",
        "limitations"
      ],
      "properties": {
        "validator_implementation_status": {"enum": ["NOT_IMPLEMENTED", "IMPLEMENTED"]},
        "validator_id": {"$ref": "#/$defs/nullableString"},
        "validator_version": {"$ref": "#/$defs/nullableString"},
        "validator_artifact_digest": {"$ref": "#/$defs/nullableDigest"},
        "schema_validation": {"enum": ["PASS", "FAIL", "NOT_ASSESSED"]},
        "semantic_validation": {"enum": ["PASS", "FAIL", "NOT_ASSESSED"]},
        "case_set_reconciliation": {"enum": ["PASS", "FAIL", "NOT_ASSESSED"]},
        "summary_reconciliation": {"enum": ["PASS", "FAIL", "NOT_ASSESSED"]},
        "catalog_digest_verified": {"type": "boolean"},
        "decision_bindings_verified": {"type": "boolean"},
        "implementation_digests_verified": {"type": "boolean"},
        "environment_binding_verified": {"type": "boolean"},
        "validation_report_ref": {
          "oneOf": [
            {"type": "null"},
            {"$ref": "#/$defs/fileReference"}
          ]
        },
        "validation_completed_at": {"$ref": "#/$defs/nullableDateTime"},
        "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "authority_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "result_set_is_gate_decision",
        "result_set_is_human_authorization",
        "result_set_can_change_runtime_state",
        "independent_gate_evaluator_required",
        "independent_reviewer_required",
        "human_decision_required_for_gate_closure"
      ],
      "properties": {
        "result_set_is_gate_decision": {"const": false},
        "result_set_is_human_authorization": {"const": false},
        "result_set_can_change_runtime_state": {"const": false},
        "independent_gate_evaluator_required": {"const": true},
        "independent_reviewer_required": {"const": true},
        "human_decision_required_for_gate_closure": {"const": true}
      }
    },
    "required_case_ids": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/caseId"},
      "uniqueItems": true
    },
    "case_results": {
      "type": "array",
      "items": {"$ref": "#/$defs/caseResult"}
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "executed", "passed", "failed", "blocked", "not_assessed", "required_case_pass_rate", "unknown_acceptance_count"],
      "properties": {
        "required": {"type": "integer", "minimum": 1, "maximum": 56},
        "executed": {"type": "integer", "minimum": 0, "maximum": 56},
        "passed": {"type": "integer", "minimum": 0, "maximum": 56},
        "failed": {"type": "integer", "minimum": 0, "maximum": 56},
        "blocked": {"type": "integer", "minimum": 0, "maximum": 56},
        "not_assessed": {"type": "integer", "minimum": 0, "maximum": 56},
        "required_case_pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
        "unknown_acceptance_count": {"type": "integer", "minimum": 0, "maximum": 56}
      }
    },
    "reviews": {"type": "array", "items": {"$ref": "#/$defs/review"}, "uniqueItems": true},
    "result": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_ASSESSED"]},
    "result_reason": {"type": "string", "minLength": 1, "maxLength": 4096},
    "frozen_at": {"$ref": "#/$defs/nullableDateTime"},
    "result_set_digest": {"$ref": "#/$defs/nullableDigest"},
    "revocation": {
      "oneOf": [
        {"type": "null"},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["reason", "reference", "revoked_at"],
          "properties": {
            "reason": {"type": "string", "minLength": 1},
            "reference": {"type": "string", "minLength": 1},
            "revoked_at": {"type": "string", "format": "date-time"}
          }
        }
      ]
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adopts_reference_version", "changes_evidence_truth", "grants_permission", "authorizes_implementation", "authorizes_deployment", "closes_production_gate", "declares_production_ready"],
      "properties": {
        "adopts_reference_version": {"const": false},
        "changes_evidence_truth": {"const": false},
        "grants_permission": {"const": false},
        "authorizes_implementation": {"const": false},
        "authorizes_deployment": {"const": false},
        "closes_production_gate": {"const": false},
        "declares_production_ready": {"const": false}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"status": {"const": "FROZEN"}}, "required": ["status"]},
      "then": {
        "properties": {
          "frozen_at": {"type": "string", "format": "date-time"},
          "result_set_digest": {"$ref": "#/$defs/digest"},
          "catalog_binding": {"properties": {"catalog_digest": {"$ref": "#/$defs/digest"}}}
        }
      }
    },
    {
      "if": {"properties": {"status": {"const": "REVOKED"}}, "required": ["status"]},
      "then": {"properties": {"revocation": {"type": "object"}}}
    },
    {
      "if": {"properties": {"result": {"const": "PASS"}}, "required": ["result"]},
      "then": {
        "properties": {
          "status": {"const": "FROZEN"},
          "synthetic_example": {"const": false},
          "summary": {
            "properties": {
              "failed": {"const": 0},
              "blocked": {"const": 0},
              "not_assessed": {"const": 0},
              "required_case_pass_rate": {"const": 1}
            }
          },
          "catalog_binding": {
            "properties": {
              "catalog_status": {"const": "ADOPTED_CONTRACT"},
              "catalog_digest": {"$ref": "#/$defs/digest"}
            }
          },
          "decision_bindings": {
            "items": {
              "properties": {
                "status": {"const": "AUTHORIZED"},
                "decision_record_digest": {"$ref": "#/$defs/digest"},
                "scope_digest": {"$ref": "#/$defs/digest"},
                "authority_registry_ref": {"type": "string", "minLength": 1},
                "decided_by_ref": {"type": "string", "minLength": 1},
                "decided_at": {"type": "string", "format": "date-time"}
              }
            }
          },
          "claim_scope": {
            "properties": {
              "topology_digest": {"$ref": "#/$defs/digest"},
              "workload_ref": {"type": "string", "minLength": 1},
              "window_started_at": {"type": "string", "format": "date-time"},
              "window_ended_at": {"type": "string", "format": "date-time"}
            }
          },
          "implementation_binding": {
            "properties": {
              "repository": {"type": "string", "format": "uri"},
              "source_commit": {"$ref": "#/$defs/commit"},
              "artifact_digest": {"$ref": "#/$defs/digest"},
              "distribution_version": {"type": "string", "minLength": 1},
              "component_manifest_digest": {"$ref": "#/$defs/digest"},
              "configuration_digest": {"$ref": "#/$defs/digest"},
              "runtime_environment_digest": {"$ref": "#/$defs/digest"}
            }
          },
          "validation_binding": {
            "properties": {
              "validator_implementation_status": {"const": "IMPLEMENTED"},
              "validator_id": {"type": "string", "minLength": 1},
              "validator_version": {"type": "string", "minLength": 1},
              "validator_artifact_digest": {"$ref": "#/$defs/digest"},
              "schema_validation": {"const": "PASS"},
              "semantic_validation": {"const": "PASS"},
              "case_set_reconciliation": {"const": "PASS"},
              "summary_reconciliation": {"const": "PASS"},
              "catalog_digest_verified": {"const": true},
              "decision_bindings_verified": {"const": true},
              "implementation_digests_verified": {"const": true},
              "environment_binding_verified": {"const": true},
              "validation_report_ref": {"$ref": "#/$defs/verifiedFileReference"},
              "validation_completed_at": {"type": "string", "format": "date-time"}
            }
          },
          "case_results": {"minItems": 1},
          "reviews": {"minItems": 1}
        }
      }
    }
  ],
  "$defs": {
    "caseId": {"type": "string", "pattern": "^OTLP-CF-[A-Z]{2,8}-[0-9]{3}$"},
    "digest": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "nullableDigest": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/digest"}]},
    "commit": {"type": "string", "pattern": "^[0-9a-f]{40}$"},
    "nullableCommit": {"oneOf": [{"type": "null"}, {"$ref": "#/$defs/commit"}]},
    "nullableString": {"oneOf": [{"type": "null"}, {"type": "string", "minLength": 1, "maxLength": 4096}]},
    "nullableUri": {"oneOf": [{"type": "null"}, {"type": "string", "format": "uri"}]},
    "nullableDateTime": {"oneOf": [{"type": "null"}, {"type": "string", "format": "date-time"}]},
    "fileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 2048},
        "digest": {"$ref": "#/$defs/nullableDigest"}
      }
    },
    "verifiedFileReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "digest"],
      "properties": {
        "path": {"type": "string", "minLength": 1, "maxLength": 2048},
        "digest": {"$ref": "#/$defs/digest"}
      }
    },
    "decisionBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "status", "reference", "decision_record_digest", "scope_digest", "authority_registry_ref", "decided_by_ref", "decided_at"],
      "properties": {
        "decision_id": {"enum": ["DQ-018", "DQ-020", "DQ-022"]},
        "status": {"enum": ["PENDING", "AUTHORIZED", "REJECTED", "REVOKED", "SUPERSEDED"]},
        "reference": {"type": "string", "minLength": 1, "maxLength": 2048},
        "decision_record_digest": {"$ref": "#/$defs/nullableDigest"},
        "scope_digest": {"$ref": "#/$defs/nullableDigest"},
        "authority_registry_ref": {"$ref": "#/$defs/nullableString"},
        "decided_by_ref": {"$ref": "#/$defs/nullableString"},
        "decided_at": {"$ref": "#/$defs/nullableDateTime"}
      }
    },
    "caseResult": {
      "type": "object",
      "additionalProperties": false,
      "required": ["case_id", "result", "expected_outcome_match", "actual_protocol_result", "actual_retry_class", "actual_acceptance_state", "unknown_acceptance_retained", "started_at", "ended_at", "observation_refs", "evidence_refs", "failure_ref", "limitations"],
      "properties": {
        "case_id": {"$ref": "#/$defs/caseId"},
        "result": {"enum": ["PASS", "FAIL", "BLOCKED", "NOT_ASSESSED"]},
        "expected_outcome_match": {"enum": ["YES", "NO", "NOT_ASSESSED"]},
        "actual_protocol_result": {"$ref": "#/$defs/nullableString"},
        "actual_retry_class": {"oneOf": [{"type": "null"}, {"enum": ["NOT_APPLICABLE", "NO_RETRY", "BOUNDED_RETRY", "UNKNOWN_UNTIL_ACK_RECONCILIATION"]}]},
        "actual_acceptance_state": {"oneOf": [{"type": "null"}, {"enum": ["NOT_ACCEPTED", "ACCEPTED_AT_HOP_ONLY", "PARTIAL_AT_HOP", "UNKNOWN", "NOT_APPLICABLE"]}]},
        "unknown_acceptance_retained": {"oneOf": [{"type": "null"}, {"type": "boolean"}]},
        "started_at": {"$ref": "#/$defs/nullableDateTime"},
        "ended_at": {"$ref": "#/$defs/nullableDateTime"},
        "observation_refs": {"type": "array", "items": {"$ref": "#/$defs/fileReference"}, "uniqueItems": true},
        "evidence_refs": {"type": "array", "items": {"$ref": "#/$defs/fileReference"}, "uniqueItems": true},
        "failure_ref": {"$ref": "#/$defs/nullableString"},
        "limitations": {"type": "array", "items": {"type": "string", "minLength": 1}, "uniqueItems": true}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["review_id", "reviewer_ref", "reviewed_at", "result", "review_ref"],
      "properties": {
        "review_id": {"type": "string", "minLength": 1},
        "reviewer_ref": {"type": "string", "minLength": 1},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "result": {"enum": ["APPROVED", "CONDITIONAL", "REJECTED", "NOT_ASSESSED"]},
        "review_ref": {"type": "string", "minLength": 1}
      }
    }
  }
}
