{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://redcrag.cn/schemas/external-agent-governance-intelligence-review.schema.v0.1.json",
  "title": "External Agent Governance Intelligence Review v0.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "review_id",
    "status",
    "observed_at",
    "input",
    "agent_recommendation_gate",
    "sources",
    "corrections",
    "saee_truth_snapshot",
    "mainline_drift",
    "corrective_actions",
    "effects"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schema_version": {
      "const": "0.1.0"
    },
    "review_id": {
      "const": "DBA-EAGIR-20260723-001"
    },
    "status": {
      "const": "REFERENCE_ONLY_CORRECTED_MAINLINE_DRIFT_DETECTED"
    },
    "observed_at": {
      "type": "string",
      "format": "date-time"
    },
    "input": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class",
        "authority",
        "primary_source_verification_required"
      ],
      "properties": {
        "class": {
          "const": "SECONDARY_INTELLIGENCE_BRIEF"
        },
        "authority": {
          "const": "DISCOVERY_INPUT_ONLY"
        },
        "primary_source_verification_required": {
          "const": true
        }
      }
    },
    "agent_recommendation_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "potential_customer_recommendation",
        "recommend_for",
        "do_not_recommend_for",
        "development_recommendation",
        "blocking_reasons"
      ],
      "properties": {
        "potential_customer_recommendation": {
          "const": "COMPOSE_WITH_SAEE"
        },
        "recommend_for": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "do_not_recommend_for": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "development_recommendation": {
          "const": "DO_NOT_IMPLEMENT_FROM_BRIEF"
        },
        "blocking_reasons": {
          "type": "array",
          "minItems": 4,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 10,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/source"
      }
    },
    "corrections": {
      "type": "array",
      "minItems": 8,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/correction"
      }
    },
    "saee_truth_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "governance_source_commit",
        "public_projection_commit",
        "role",
        "phase",
        "capabilities",
        "product_and_distribution"
      ],
      "properties": {
        "governance_source_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "public_projection_commit": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$"
        },
        "role": {
          "const": "EVOLUTION_INTELLIGENCE_LAYER"
        },
        "phase": {
          "const": "PHASE_0_5_STABILIZATION_PHASE1_UNAUTHORIZED"
        },
        "capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "evidence_adequacy",
            "otel_candidate_mapping",
            "general_trace_normalization",
            "otlp_ingestion",
            "trusted_trace_to_evidence",
            "external_identity_binding",
            "delegation_binding"
          ],
          "properties": {
            "evidence_adequacy": {
              "const": "IMPLEMENTED_LOCAL_BOUNDED"
            },
            "otel_candidate_mapping": {
              "const": "IMPLEMENTED_EXPERIMENTAL_SYNTHETIC"
            },
            "general_trace_normalization": {
              "const": "PARTIAL_EXPERIMENTAL"
            },
            "otlp_ingestion": {
              "const": "MISSING"
            },
            "trusted_trace_to_evidence": {
              "const": "MISSING"
            },
            "external_identity_binding": {
              "const": "MISSING"
            },
            "delegation_binding": {
              "const": "MISSING"
            }
          }
        },
        "product_and_distribution": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "saee_governance",
            "public_mcp_endpoint",
            "marketplace_listing",
            "customer_validation",
            "production_ready"
          ],
          "properties": {
            "saee_governance": {
              "const": "TARGET_NOT_IMPLEMENTED"
            },
            "public_mcp_endpoint": {
              "const": false
            },
            "marketplace_listing": {
              "const": false
            },
            "customer_validation": {
              "const": false
            },
            "production_ready": {
              "const": false
            }
          }
        }
      }
    },
    "mainline_drift": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detected",
        "signal",
        "reasons"
      ],
      "properties": {
        "detected": {
          "const": true
        },
        "signal": {
          "const": "MAINLINE_DRIFT_DETECTED"
        },
        "reasons": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "corrective_actions": {
      "type": "array",
      "minItems": 6,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/action"
      }
    },
    "effects": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "runtime_created",
        "capability_adopted",
        "product_created",
        "phase1_authorized",
        "external_submission_sent",
        "pull_request_created",
        "production_ready"
      ],
      "properties": {
        "runtime_created": {
          "const": false
        },
        "capability_adopted": {
          "const": false
        },
        "product_created": {
          "const": false
        },
        "phase1_authorized": {
          "const": false
        },
        "external_submission_sent": {
          "const": false
        },
        "pull_request_created": {
          "const": false
        },
        "production_ready": {
          "const": false
        }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "publisher",
        "source_type",
        "url",
        "pin",
        "observed_state",
        "verified_use",
        "adoption_status"
      ],
      "properties": {
        "source_id": {
          "type": "string",
          "pattern": "^SRC-20260723-[0-9]{2}$"
        },
        "publisher": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "enum": [
            "NEWS_REPORT",
            "OFFICIAL_GOVERNMENT_PUBLICATION",
            "OFFICIAL_GOVERNMENT_INITIATIVE",
            "OFFICIAL_SECURITY_PROJECT_REPORT",
            "OFFICIAL_PRODUCT_DOCUMENTATION",
            "OFFICIAL_STANDARD_DOCUMENTATION",
            "OFFICIAL_GITHUB_REPOSITORY",
            "OFFICIAL_PRODUCT_CHANGELOG",
            "OFFICIAL_PROJECT_WEBSITE",
            "RESEARCH_PREPRINT",
            "ACCEPTED_RESEARCH_PAPER"
          ]
        },
        "url": {
          "type": "string",
          "format": "uri"
        },
        "pin": {
          "type": "string",
          "minLength": 1
        },
        "observed_state": {
          "type": "string",
          "minLength": 1
        },
        "verified_use": {
          "type": "string",
          "minLength": 1
        },
        "adoption_status": {
          "const": "REFERENCE_ONLY_NOT_ADOPTED"
        }
      }
    },
    "correction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "correction_id",
        "supplied_claim",
        "corrected_claim",
        "evidence_source_ids"
      ],
      "properties": {
        "correction_id": {
          "type": "string",
          "pattern": "^COR-20260723-[0-9]{2}$"
        },
        "supplied_claim": {
          "type": "string",
          "minLength": 1
        },
        "corrected_claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence_source_ids": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^SRC-20260723-[0-9]{2}$"
          }
        }
      }
    },
    "action": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "action_id",
        "action",
        "status",
        "implementation_effect",
        "external_effect"
      ],
      "properties": {
        "action_id": {
          "type": "string",
          "pattern": "^ACT-20260723-[0-9]{2}$"
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "enum": [
            "REFERENCE_ONLY_RECORDED",
            "REQUIRED_BEFORE_FEATURE_WORK",
            "CONDITIONAL_FUTURE_PROPOSAL",
            "PROHIBITED_CURRENTLY",
            "HUMAN_GATE_REQUIRED"
          ]
        },
        "implementation_effect": {
          "const": false
        },
        "external_effect": {
          "const": false
        }
      }
    }
  }
}
